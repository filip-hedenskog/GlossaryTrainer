<Window x:Class="GlossaryTrainer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        Title="Glossary Trainer"
        Width="600"
        Height="500"
        prism:ViewModelLocator.AutoWireViewModel="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Visibility="{Binding IsQuizStarted, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="Select glossary"
               FontSize="22"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <ComboBox ItemsSource="{Binding AvailableGlossaries}"
              SelectedItem="{Binding SelectedGlossary}"
              DisplayMemberPath="Name"
              Height="35"
              FontSize="16"
              Margin="0,0,0,15"/>

            <Button Content="Start"
                    IsDefault="True"
            Command="{Binding StartCommand}"
            Height="35"/>
        </StackPanel>

        <!-- Quiz -->
        <StackPanel Orientation="Vertical" Visibility="{Binding IsQuizStarted, Converter={StaticResource BooleanToVisibilityConverter}}">

            <TextBlock
                Text="{Binding CurrentWord}"
                FontSize="24"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>

            <TextBox
                x:Name="UserInputTextBox"
                Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                Height="42"
                FontSize="30"
                FontFamily="Yu Gothic UI"
                FontWeight="Bold"
                Margin="0,0,0,10"
                VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFinished}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button
                Content="Submit"
                IsDefault="True"
                Command="{Binding SubmitCommand}"
                Height="30"/>

            <TextBlock Text="{Binding FeedbackText}"
           Foreground="{Binding FeedbackColor}"
           FontFamily="Yu Gothic UI"
           FontWeight="Bold"
           FontSize="30"
           HorizontalAlignment="Left"
           Margin="0,5,0,10"/>
        </StackPanel>

        <!-- Result -->
        <StackPanel Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding IsFinished, Converter={StaticResource BooleanToVisibilityConverter}}">

            <TextBlock Text="{Binding ScoreText}"
               FontSize="22"
               FontWeight="Bold"
               Margin="0,0,0,20"
               HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Restart"
                Command="{Binding RestartCommand}"
                Width="120"
                Height="30"
                Margin="0,0,10,0"/>

                <Button Content="Select glossary"
                Command="{Binding SelectGlossaryCommand}"
                Width="140"
                Height="30"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>